# Base de datos (Supabase)
# Formato: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://...

# JWT — generar un valor aleatorio seguro para producción
SECRET_KEY=cambia-esto-en-produccion

# OpenAI
OPENAI_API_KEY=sk-...

# Pinecone
PINECONE_API_KEY=...

# Neo4j AuraDB
# Formato: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://...
NEO4J_USER=neo4j
NEO4J_PASSWORD=...

# URL del frontend en Vercel (sin barra final)
# Ejemplo: https://tutor-frontend.vercel.app
FRONTEND_URL=https://...
